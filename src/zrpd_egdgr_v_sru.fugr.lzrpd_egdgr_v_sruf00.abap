FORM CORR_MAINT_ZRPD_EGDGR_V_SRU USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE ZRPD_EGDGR_V_SRU-FORM_ID TO
ZRPD_EGDGR_SRU-FORM_ID .
MOVE ZRPD_EGDGR_V_SRU-KAT_ID TO
ZRPD_EGDGR_SRU-KAT_ID .
MOVE ZRPD_EGDGR_V_SRU-SORU_ID TO
ZRPD_EGDGR_SRU-SORU_ID .
MOVE ZRPD_EGDGR_V_SRU-MANDT TO
ZRPD_EGDGR_SRU-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = 'ZRPD_EGDGR_SRU'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN ZRPD_EGDGR_SRU TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING 'ZRPD_EGDGR_SRU'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
